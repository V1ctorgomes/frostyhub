PORT=3001
NODE_ENV=production

# Hostname do container PostgreSQL na rede Docker (não use localhost em produção)
DATABASE_URL=postgresql://postgres:senha@nome-do-servico-postgres:5432/frosthub_db

# URL pública do frontend (usada no CORS)
FRONTEND_URL=https://seu-frontend.easypanel.host

JWT_SECRET=uma_chave_secreta_forte_e_unica
